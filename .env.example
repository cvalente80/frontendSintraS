# Copy to .env.local and fill with your Firebase project config
# These are used by Vite at build-time (client-side)
VITE_FIREBASE_API_KEY=YOUR_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_BUCKET
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID
VITE_FIREBASE_MEASUREMENT_ID=YOUR_MEASUREMENT_ID

# Optional Google tracking for GA4 / GTM / Google Ads
# Use GTM if you want to manage tags centrally.
VITE_GOOGLE_TAG_MANAGER_ID=

# Use GA4 measurement ID if you want direct gtag page/event tracking.
VITE_GA4_MEASUREMENT_ID=

# Google Ads conversion ID (format: AW-XXXXXXXXX)
VITE_GOOGLE_ADS_CONVERSION_ID=

# Google Ads conversion labels for each event type
VITE_GOOGLE_ADS_LABEL_QUOTE_START=
VITE_GOOGLE_ADS_LABEL_WHATSAPP_CLICK=
VITE_GOOGLE_ADS_LABEL_GENERATE_LEAD=
VITE_GOOGLE_ADS_LABEL_PHONE_CLICK=
